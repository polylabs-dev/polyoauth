// Poly OAuth Risk — ESLM-powered authentication risk scoring (v0.11.0)
//
// Lex Architecture:
//   esn/global/org/polylabs/oauth/risk
//   On-device ESLM for initial scoring; server-side for cross-session correlation.
//   ai_feed auth_anomaly drives behavioral baseline learning.
//   Risk factors: geo-velocity, device trust, temporal patterns, network signals.

import polykit_identity
import polykit_metering

data RiskScore : oauth v1 {
    overall: u16,
    geo_velocity: u16,
    device_trust: u16,
    temporal: u16,
    network: u16,
    behavioral: u16,
    requires_step_up: bool,
    requires_block: bool,
}
    store kv
    govern lex esn/global/org/polylabs/oauth/risk
    cortex {
        infer on_write
        on_anomaly alert "oauth-security"
    }

type RiskFactors = struct {
    user_id: bytes(16),
    device_fingerprint_hash: bytes(32),
    geo_hash: bytes(8),
    ip_hash: bytes(32),
    timestamp_ns: u64,
    user_agent_hash: bytes(32),
    is_known_device: bool,
    is_known_network: bool,
    auth_method: u8,
}

data AnomalySignal : oauth v1 {
    signal_type: u8,
    severity: u16,
    description_hash: bytes(32),
    evidence_hash: bytes(32),
    timestamp_ns: u64,
}
    store kv
    govern lex esn/global/org/polylabs/oauth/risk
    cortex {
        infer on_write
        on_anomaly alert "oauth-security"
        on_suggestion store "cortex/oauth/anomalies"
    }

type GeoVelocity = struct {
    previous_geo_hash: bytes(8),
    current_geo_hash: bytes(8),
    previous_timestamp_ns: u64,
    current_timestamp_ns: u64,
    distance_km: u32,
    time_delta_s: u64,
    velocity_kmh: u32,
    impossible_travel: bool,
}

data UserBaseline : oauth v1 {
    user_id: bytes(16),
    typical_geo_hashes: [bytes(8); 8],
    typical_hours: bytes(3),
    known_devices: [bytes(32); 8],
    known_networks: [bytes(32); 8],
    avg_session_duration_ms: u64,
    login_frequency_per_day: u16,
    last_updated: u64,
}
    store kv
    govern lex esn/global/org/polylabs/oauth/risk
    cortex {
        obfuscate [user_id]
        infer on_write
        on_anomaly alert "oauth-team"
    }

ai_feed auth_anomaly {
    input: RiskFactors,
    output: AnomalySignal,
    model: eslm_v1,
    baseline_window: 120,
    anomaly_threshold: 0.85,
}

stream risk_events: event<RiskScore>
    | throttle 2000/s burst 4000

stream anomaly_events: event<AnomalySignal>
    retention 365d
    consumers [streamsight, eslm, oauth_security]

// --- Evaluate overall risk for an authentication attempt ---
circuit evaluate_risk(factors: RiskFactors, baseline: UserBaseline) -> RiskScore
    profile poly_framework_sensitive
    lex esn/global/org/polylabs/oauth/risk
    precision C
    constant_time true
    observe metrics: [risk_evaluations, high_risk_count, step_up_triggers, block_triggers]
    monitor "risk_evaluation_latency" { risk_eval_latency_ns < 5000000 }
    invariant "score_bounded" { overall <= 1000 }
    property safety "high_risk_blocks" { overall > 800 implies requires_block }
    property safety "elevated_risk_step_up" { overall > 500 implies requires_step_up }
    meters [compute_cycles, memory_bytes]
    wasm_abi [eslite_query, stream_emit, now]
{
    let geo = check_geo_velocity(factors.user_id, factors.geo_hash, factors.timestamp_ns, baseline)
    let device = score_device_trust(factors.device_fingerprint_hash, factors.is_known_device, baseline)
    let anomaly = detect_anomaly(factors, baseline)

    let temporal = score_temporal(factors.timestamp_ns, baseline)
    let network = if factors.is_known_network { 0 } else { 200 }

    let geo_weight = 300
    let device_weight = 250
    let temporal_weight = 150
    let network_weight = 100
    let behavioral_weight = 200

    let weighted_sum = (geo.velocity_kmh > 1000 ? 1000 : geo_score(geo)) * geo_weight / 1000 +
                       device * device_weight / 1000 +
                       temporal * temporal_weight / 1000 +
                       network * network_weight / 1000 +
                       anomaly.severity * behavioral_weight / 1000

    let overall = min(weighted_sum, 1000)

    let score = RiskScore {
        overall: overall,
        geo_velocity: geo_score(geo),
        device_trust: device,
        temporal: temporal,
        network: network,
        behavioral: anomaly.severity,
        requires_step_up: overall > 500,
        requires_block: overall > 800,
    }

    emit(risk_events, score)
    score
}

// --- Check geo-velocity (impossible travel detection) ---
circuit check_geo_velocity(user_id: bytes(16), current_geo: bytes(8), current_ts: u64, baseline: UserBaseline) -> GeoVelocity
    profile poly_framework_standard
    lex esn/global/org/polylabs/oauth/risk
    precision B
    observe metrics: [geo_velocity_checks, impossible_travel_detections]
    monitor "impossible_travel_rate" { impossible_travel_detections < 5/s }
{
    let last_session = load_last_session(user_id)
    let prev_geo = last_session.geo_hash
    let prev_ts = last_session.timestamp_ns

    let distance_km = geohash_distance(prev_geo, current_geo)
    let time_delta_s = (current_ts - prev_ts) / 1000000000

    let velocity_kmh = if time_delta_s > 0 { distance_km * 3600 / time_delta_s } else { 999999 }

    let impossible = velocity_kmh > 1000

    let is_known_location = array_contains(baseline.typical_geo_hashes, current_geo)

    GeoVelocity {
        previous_geo_hash: prev_geo,
        current_geo_hash: current_geo,
        previous_timestamp_ns: prev_ts,
        current_timestamp_ns: current_ts,
        distance_km: distance_km,
        time_delta_s: time_delta_s,
        velocity_kmh: velocity_kmh,
        impossible_travel: impossible and !is_known_location,
    }
}

// --- Score device trust level ---
circuit score_device_trust(device_hash: bytes(32), is_known: bool, baseline: UserBaseline) -> u16
    profile poly_framework_standard
    lex esn/global/org/polylabs/oauth/risk
    precision B
    observe metrics: [device_trust_evaluations, unknown_device_count]
{
    let in_baseline = array_contains(baseline.known_devices, device_hash)

    match (is_known, in_baseline) {
        (true, true) => 0,
        (true, false) => 200,
        (false, true) => 300,
        (false, false) => 700,
    }
}

// --- Detect behavioral anomalies via ESLM ---
circuit detect_anomaly(factors: RiskFactors, baseline: UserBaseline) -> AnomalySignal
    profile poly_framework_sensitive
    lex esn/global/org/polylabs/oauth/risk
    precision C
    observe metrics: [anomaly_detections, anomaly_severity_sum]
    monitor "anomaly_rate" { anomaly_detections < 20/s }
    wasm_abi [stream_emit, now]
{
    let eslm_result = eslm_evaluate(auth_anomaly, factors)

    let freq_deviation = abs(login_count_today(factors.user_id) - baseline.login_frequency_per_day)
    let freq_anomaly = freq_deviation > baseline.login_frequency_per_day * 3

    let severity = eslm_result.confidence * 1000
    let combined = if freq_anomaly { min(severity + 200, 1000) } else { severity }

    let signal = AnomalySignal {
        signal_type: eslm_result.signal_type,
        severity: combined,
        description_hash: sha3_256(eslm_result.description),
        evidence_hash: sha3_256(serialize(factors)),
        timestamp_ns: now_ns(),
    }

    if combined > 500 {
        emit(anomaly_events, signal)
    }
    signal
}

// --- Update user baseline from successful authentication ---
circuit update_baseline(user_id: bytes(16), factors: RiskFactors, current_baseline: UserBaseline) -> UserBaseline
    profile poly_framework_standard
    lex esn/global/org/polylabs/oauth/risk
    precision B
    observe metrics: [baseline_updates]
    invariant "baseline_owner" { user_id == current_baseline.user_id }
    property safety "baseline_monotonic" { output.last_updated >= current_baseline.last_updated }
    meters [compute_cycles, memory_bytes]
    wasm_abi [eslite_insert, now]
{
    let ts = now_ns() / 1000000

    let updated_geos = ring_insert(current_baseline.typical_geo_hashes, factors.geo_hash)
    let updated_devices = ring_insert(current_baseline.known_devices, factors.device_fingerprint_hash)
    let updated_networks = ring_insert(current_baseline.known_networks, factors.ip_hash)

    let hour = extract_hour(factors.timestamp_ns)
    let updated_hours = bitmask_set(current_baseline.typical_hours, hour)

    let updated_freq = ewma(current_baseline.login_frequency_per_day,
                            login_count_today(user_id), 0.1)

    let updated = UserBaseline {
        user_id: user_id,
        typical_geo_hashes: updated_geos,
        typical_hours: updated_hours,
        known_devices: updated_devices,
        known_networks: updated_networks,
        avg_session_duration_ms: current_baseline.avg_session_duration_ms,
        login_frequency_per_day: updated_freq,
        last_updated: ts,
    }

    eslite_insert(user_id, updated)
    updated
}

// ── Test / KAT / Fuzz annotations ──────────────────────────────

test golden "evaluate_low_risk" {
    input {
        factors: RiskFactors {
            user_id: hex("01" * 16), device_fingerprint_hash: hex("AA" * 32),
            geo_hash: hex("01" * 8), ip_hash: hex("BB" * 32),
            timestamp_ns: 1000000000000, user_agent_hash: hex("CC" * 32),
            is_known_device: true, is_known_network: true, auth_method: 0,
        }
        baseline: UserBaseline {
            user_id: hex("01" * 16), typical_geo_hashes: [hex("01" * 8); 8],
            typical_hours: hex("FF" * 3), known_devices: [hex("AA" * 32); 8],
            known_networks: [hex("BB" * 32); 8], avg_session_duration_ms: 3600000,
            login_frequency_per_day: 5, last_updated: 0,
        }
    }
    assert {
        score.overall <= 200
        score.requires_step_up == false
        score.requires_block == false
    }
}

test golden "evaluate_impossible_travel" {
    input {
        factors: RiskFactors {
            user_id: hex("01" * 16), device_fingerprint_hash: hex("FF" * 32),
            geo_hash: hex("FF" * 8), ip_hash: hex("FF" * 32),
            timestamp_ns: 1000000000000, user_agent_hash: hex("FF" * 32),
            is_known_device: false, is_known_network: false, auth_method: 0,
        }
        baseline: UserBaseline {
            user_id: hex("01" * 16), typical_geo_hashes: [hex("01" * 8); 8],
            typical_hours: hex("00" * 3), known_devices: [hex("AA" * 32); 8],
            known_networks: [hex("BB" * 32); 8], avg_session_duration_ms: 3600000,
            login_frequency_per_day: 5, last_updated: 0,
        }
    }
    assert {
        score.overall > 500
        score.requires_step_up == true
    }
}

fuzz_target "evaluate_risk_fuzz" {
    inputs {
        factors: RiskFactors
        baseline: UserBaseline
    }
    assert {
        no_panic
        constant_time true
        output.overall <= 1000
    }
}
